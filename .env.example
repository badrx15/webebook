# Square Payment Gateway Configuration
# Get these values from your Square Developer Dashboard: https://developer.squareup.com

# Square Application ID (public, used in the Web Payments SDK on client side)
NEXT_PUBLIC_SQUARE_APP_ID=sandbox-sq0idb-YOUR_APP_ID_HERE

# Square Location ID (your business location - public)
NEXT_PUBLIC_SQUARE_LOCATION_ID=YOUR_LOCATION_ID_HERE

# Square Environment for client-side: 'production' or leave empty for sandbox
NEXT_PUBLIC_SQUARE_ENV=sandbox

# Square Access Token (secret, keep private! Never expose to client!)
SQUARE_ACCESS_TOKEN=EAAA_YOUR_SECRET_TOKEN_HERE

# Square Environment for API (server-side): 'sandbox' or 'production'
SQUARE_ENVIRONMENT=sandbox

# === How to get Square credentials ===
# 1. Go to https://developer.squareup.com and sign up / log in
# 2. Create a new application
# 3. In the Credentials tab, copy:
#    - Application ID → NEXT_PUBLIC_SQUARE_APP_ID
#    - Location ID → NEXT_PUBLIC_SQUARE_LOCATION_ID
#    - Access Token → SQUARE_ACCESS_TOKEN
# 4. For production:
#    - Change NEXT_PUBLIC_SQUARE_ENV to 'production'
#    - Change SQUARE_ENVIRONMENT to 'production'
#    - Use your production credentials
